{
  "expo": {
    "name": "Gym Tracker",
    "slug": "app-gestion-evaluaciones-uvm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF5757"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uvm.evaluaciones"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF5757"
      },
      "package": "com.uvm.evaluaciones"
    },
    "web": {
      "favicon": "./assets/favicon.ico"
    },
    "extra": {
      "eas": {
        "projectId": "8d48f9f7-0088-47dc-9788-453d6a24b62a"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
